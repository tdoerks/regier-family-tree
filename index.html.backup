                    generation: 2,
                    line: 'doerksen',
                    location: '',
                    children: ['daen', 'shaedon', 'tyler', 'kelsey', 'brock'],
                    notes: 'Sharon had previous marriage with Daen and Shaedon'
                },
                {
                    id: 'christopher',
                    name: 'Christopher Doerksen & Crystal Linscott',
                    parents: 'marion-harold',
                    generation: 2,
