                    line: 'doerksen',
                    location: ''
                }
            ]
        };

        // Helper function to get all family members as flat array
        function getAllMembers() {
            return [...familyData.gen1, ...familyData.gen2, ...familyData.gen3, ...familyData.gen4];
        }

        // Helper function to find person by ID
        function findPerson(id) {
            return getAllMembers().find(p => p.id === id);
        }

        // Helper function to get children of a person
        function getChildren(personId) {
            const person = findPerson(personId);
            if (!person || !person.children || person.children.length === 0) return [];
            return person.children.map(childId => findPerson(childId)).filter(c => c);
        }

        // Render family tree
        function renderFamilyTree(members = getAllMembers()) {
            const container = document.getElementById('familyTreeContainer');
            container.innerHTML = '';

            // Start with generation 1 (roots)
            const roots = members.filter(p => p.generation === 1);

            roots.forEach(root => {
                const familyLine = document.createElement('div');
                familyLine.className = `family-line ${root.line}`;
                familyLine.appendChild(renderPerson(root, members));
                container.appendChild(familyLine);
            });
        }

        // Render individual person card
        function renderPerson(person, visibleMembers) {
            const personDiv = document.createElement('div');
            const children = getChildren(person.id).filter(c => visibleMembers.includes(c));
            const hasChildren = children.length > 0;

            personDiv.className = `person ${hasChildren ? 'expandable' : ''}`;
            if (hasChildren) {
                personDiv.onclick = () => toggleChildren(person.id);
            }

            let html = '<div class="person-name">';
            if (hasChildren) {
                html += `<span class="expand-icon" id="icon-${person.id}">▶</span>`;
            }
            html += person.name;
            html += '</div>';

            html += '<div class="person-details">';
            if (person.location) {
                html += `<span>📍 ${person.location}</span>`;
            }
            html += `<span>Gen ${person.generation}</span>`;
            if (person.notes) {
                html += `<span>ℹ️ ${person.notes}</span>`;
            }
            html += '</div>';

            personDiv.innerHTML = html;

            // Add children container
            if (hasChildren) {
                const childrenDiv = document.createElement('div');
                childrenDiv.className = 'children';
                childrenDiv.id = `children-${person.id}`;

                children.forEach(child => {
                    childrenDiv.appendChild(renderPerson(child, visibleMembers));
                });

                personDiv.appendChild(childrenDiv);
            }

            return personDiv;
        }

        // Toggle children visibility
        function toggleChildren(personId) {
            const childrenDiv = document.getElementById(`children-${personId}`);
            const icon = document.getElementById(`icon-${personId}`);

            if (childrenDiv) {
                childrenDiv.classList.toggle('expanded');
                if (icon) {
                    icon.textContent = childrenDiv.classList.contains('expanded') ? '▼' : '▶';
                }
            }
        }

        // Search functionality
        function searchFamily() {
            const searchTerm = document.getElementById('searchInput').value.toLowerCase();
            const allMembers = getAllMembers();

            if (!searchTerm) {
                renderFamilyTree(allMembers);
                return;
            }

            const matches = allMembers.filter(person =>
                person.name.toLowerCase().includes(searchTerm) ||
                (person.location && person.location.toLowerCase().includes(searchTerm))
            );

            // Include ancestors and descendants of matches
            const expanded = new Set(matches);
            matches.forEach(person => {
                // Add ancestors
                let current = person;
                while (current.parents) {
                    const parent = findPerson(current.parents);
                    if (parent) {
                        expanded.add(parent);
                        current = parent;
                    } else break;
                }

                // Add descendants
                addDescendants(person.id, expanded);
            });

            renderFamilyTree([...expanded]);
        }

        // Helper to add all descendants
        function addDescendants(personId, set) {
            const children = getChildren(personId);
            children.forEach(child => {
                set.add(child);
                addDescendants(child.id, set);
            });
        }

        // Filter functionality
        function filterFamily() {
            const lineFilter = document.getElementById('lineFilter').value;
            const locationFilter = document.getElementById('locationFilter').value;
            const genFilter = document.getElementById('genFilter').value;

            let filtered = getAllMembers();

            if (lineFilter !== 'all') {
                filtered = filtered.filter(p => p.line === lineFilter);
            }

            if (locationFilter !== 'all') {
                filtered = filtered.filter(p => p.location === locationFilter);
            }

            if (genFilter !== 'all') {
                filtered = filtered.filter(p => p.generation === parseInt(genFilter));
            }

            // Include ancestors of filtered results
            const expanded = new Set(filtered);
            filtered.forEach(person => {
                let current = person;
                while (current.parents) {
                    const parent = findPerson(current.parents);
                    if (parent) {
                        expanded.add(parent);
                        current = parent;
                    } else break;
                }
            });

            renderFamilyTree([...expanded]);
        }

        // Populate location filter
        function populateLocationFilter() {
            const locations = new Set();
            getAllMembers().forEach(person => {
                if (person.location) locations.add(person.location);
            });

            const select = document.getElementById('locationFilter');
            locations.forEach(location => {
                const option = document.createElement('option');
                option.value = location;
                option.textContent = location;
                select.appendChild(option);
            });
        }

        // Calculate statistics
        function calculateStats() {
            const all = getAllMembers();
            const stats = {
                total: all.length,
                gen1: all.filter(p => p.generation === 1).length,
                gen2: all.filter(p => p.generation === 2).length,
                gen3: all.filter(p => p.generation === 3).length,
                gen4: all.filter(p => p.generation === 4).length,
                doerksenLine: all.filter(p => p.line === 'doerksen').length,
                hermanLine: all.filter(p => p.line === 'herman').length,
                peteLine: all.filter(p => p.line === 'pete').length,
                ruthLine: all.filter(p => p.line === 'ruth').length,
                ivanLine: all.filter(p => p.line === 'ivan').length
            };

            const container = document.getElementById('statsContainer');
            container.innerHTML = `
                <div class="stat-card">
                    <div class="stat-number">${stats.total}</div>
                    <div class="stat-label">Total Family Members</div>
                </div>
                <div class="stat-card">
                    <div class="stat-number">${stats.gen2}</div>
                    <div class="stat-label">Grandparents (Gen 2)</div>
                </div>
                <div class="stat-card">
                    <div class="stat-number">${stats.gen3}</div>
                    <div class="stat-label">Parents (Gen 3)</div>
                </div>
                <div class="stat-card">
                    <div class="stat-number">${stats.gen4}</div>
                    <div class="stat-label">Children (Gen 4)</div>
                </div>
                <div class="stat-card">
                    <div class="stat-number">${stats.doerksenLine}</div>
                    <div class="stat-label">Doerksen Line</div>
                </div>
            `;
        }

        // Generate Who's Who table
        function generateWhosWho() {
            const all = getAllMembers();
            const container = document.getElementById('whosWhoContainer');

            let html = `
                <table style="width: 100%; border-collapse: collapse;">
                    <thead>
                        <tr style="background: var(--doerksen); color: white;">
                            <th style="padding: 12px; text-align: left;">Name</th>
                            <th style="padding: 12px; text-align: left;">Generation</th>
                            <th style="padding: 12px; text-align: left;">Family Line</th>
                            <th style="padding: 12px; text-align: left;">Location</th>
                        </tr>
                    </thead>
                    <tbody>
            `;

            all.sort((a, b) => {
                if (a.generation !== b.generation) return a.generation - b.generation;
                return a.name.localeCompare(b.name);
            }).forEach((person, idx) => {
                const bgColor = idx % 2 === 0 ? 'var(--bg-light)' : 'white';
                html += `
                    <tr style="background: ${bgColor};">
                        <td style="padding: 12px; border-bottom: 1px solid var(--border);">${person.name}</td>
                        <td style="padding: 12px; border-bottom: 1px solid var(--border);">Generation ${person.generation}</td>
                        <td style="padding: 12px; border-bottom: 1px solid var(--border);">
                            <span style="display: inline-block; width: 12px; height: 12px; border-radius: 3px; background: var(--${person.line}); margin-right: 8px;"></span>
                            ${person.line.charAt(0).toUpperCase() + person.line.slice(1)}
                        </td>
                        <td style="padding: 12px; border-bottom: 1px solid var(--border);">${person.location || '-'}</td>
                    </tr>
                `;
            });

            html += '</tbody></table>';
            container.innerHTML = html;
        }

        // Generate Family Bingo
        function generateBingo() {
            const bingoPrompts = [
                "Find someone born in the same state as you",
                "Meet someone who shares your first initial",
                "Find a cousin you've never met before",
                "Talk to someone from Generation 1 or 2",
                "Meet all of Jerry & Sharon's kids",
                "Find someone who lives in a different state",
                "Meet someone from Christopher & Crystal's family",
                "Talk to someone named after a family member",
                "Find someone who's been to a previous reunion",
                "Meet someone from the Glover family line",
                "Find someone with the same number of siblings",
                "Talk to the youngest person at the reunion",
                "Meet someone from Whitney & Aaron's family",
                "Find someone who knows Marion & Harold's story",
                "Talk to someone from Sterling & Kyla's family",
                "Meet someone you only knew from photos",
                "Find a great-grandchild (Gen 4)",
                "Talk to someone about family history",
                "Meet someone from Saylor & Bobbie's family",
                "Find someone who can name all 8 Gen 2 families",
                "Meet someone from Autumn & Brandon's family",
                "Talk to someone about their favorite family memory",
                "Find someone who knows a family recipe",
                "Meet all the children of one Gen 2 couple"
            ];

            // Shuffle and pick 9 for 3x3 bingo
            const shuffled = bingoPrompts.sort(() => Math.random() - 0.5);
            const selected = shuffled.slice(0, 9);

            const container = document.getElementById('bingoContainer');
            let html = '<div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 10px; max-width: 600px; margin: 0 auto;">';

            selected.forEach((prompt, idx) => {
                const saved = localStorage.getItem(`bingo-${idx}`) === 'true';
                html += `
                    <div id="bingo-${idx}" onclick="toggleBingo(${idx})" style="
                        padding: 20px;
                        background: ${saved ? 'var(--doerksen)' : 'white'};
                        color: ${saved ? 'white' : 'var(--text-dark)'};
                        border: 2px solid var(--doerksen);
                        border-radius: 8px;
                        cursor: pointer;
                        text-align: center;
                        min-height: 100px;
                        display: flex;
                        align-items: center;
                        justify-content: center;
                        transition: all 0.3s;
                        font-size: 14px;
                    ">
                        ${saved ? '✓ ' : ''}${prompt}
                    </div>
                `;
            });

            html += '</div>';
            html += `
                <div style="text-align: center; margin-top: 20px;">
                    <button onclick="resetBingo()" style="padding: 10px 20px; background: var(--donald); color: white; border: none; border-radius: 6px; cursor: pointer;">
                        Reset Bingo Card
                    </button>
                </div>
            `;

            container.innerHTML = html;
        }

        function toggleBingo(idx) {
            const current = localStorage.getItem(`bingo-${idx}`) === 'true';
            localStorage.setItem(`bingo-${idx}`, (!current).toString());
            generateBingo();
        }

        function resetBingo() {
            for (let i = 0; i < 9; i++) {
                localStorage.removeItem(`bingo-${i}`);
            }
            generateBingo();
        }

        // Generate Reunion Passport
        function generatePassport() {
            const familyLines = [
                { id: 'marion-harold', name: 'Marion & Harold', color: 'doerksen' },
                { id: 'jerry', name: 'Jerry & Sharon', color: 'doerksen' },
                { id: 'christopher', name: 'Christopher & Crystal', color: 'doerksen' },
                { id: 'autumn', name: 'Autumn & Brandon', color: 'doerksen' },
                { id: 'jeremy', name: 'Jeremy & Brenda', color: 'doerksen' },
                { id: 'gwendolyn', name: 'Gwendolyn & Stan', color: 'doerksen' },
                { id: 'wayne', name: 'Wayne & Janette', color: 'doerksen' },
                { id: 'twila', name: 'Twila & Doug', color: 'doerksen' }
            ];

            const container = document.getElementById('passportContainer');
            let html = '<div style="max-width: 800px; margin: 0 auto;">';
            html += '<p style="margin-bottom: 20px;">Collect stamps by meeting at least one person from each family line!</p>';

            familyLines.forEach(line => {
                const stamped = localStorage.getItem(`passport-${line.id}`) === 'true';
                const members = getChildren(line.id);

                html += `
                    <div style="
                        background: white;
                        border: 3px solid var(--${line.color});
                        border-radius: 12px;
                        padding: 20px;
                        margin-bottom: 15px;
                        position: relative;
                    ">
                        <div style="display: flex; justify-content: space-between; align-items: center;">
                            <div>
                                <h3 style="margin: 0 0 10px 0; color: var(--${line.color});">${line.name}</h3>
                                <p style="margin: 0; color: var(--text-light); font-size: 14px;">
                                    ${members.length} family member${members.length !== 1 ? 's' : ''}
                                </p>
                            </div>
                            <button onclick="togglePassport('${line.id}')" style="
                                padding: 10px 20px;
                                background: ${stamped ? 'var(--pete)' : 'var(--border)'};
                                color: ${stamped ? 'white' : 'var(--text-dark)'};
                                border: none;
                                border-radius: 6px;
                                cursor: pointer;
                                font-size: 16px;
                            ">
                                ${stamped ? '✓ Stamped' : 'Get Stamp'}
                            </button>
                        </div>
                        ${stamped ? '<div style="position: absolute; top: 10px; right: 10px; font-size: 48px; opacity: 0.3;">✓</div>' : ''}
                    </div>
                `;
            });

            html += '</div>';

            const stamped = familyLines.filter(line => localStorage.getItem(`passport-${line.id}`) === 'true').length;
            html += `
                <div style="text-align: center; margin-top: 30px; padding: 20px; background: var(--bg-light); border-radius: 12px;">
                    <h3>Progress: ${stamped} / ${familyLines.length} families visited</h3>
                    <button onclick="resetPassport()" style="margin-top: 10px; padding: 10px 20px; background: var(--donald); color: white; border: none; border-radius: 6px; cursor: pointer;">
                        Reset Passport
                    </button>
                </div>
            `;

            container.innerHTML = html;
        }

        function togglePassport(lineId) {
            const current = localStorage.getItem(`passport-${lineId}`) === 'true';
            localStorage.setItem(`passport-${lineId}`, (!current).toString());
            generatePassport();
        }

        function resetPassport() {
            const familyLines = ['marion-harold', 'jerry', 'christopher', 'autumn', 'jeremy', 'gwendolyn', 'wayne', 'twila'];
            familyLines.forEach(line => localStorage.removeItem(`passport-${line}`));
            generatePassport();
        }

        // Generate Relationship Quiz
        function generateQuiz() {
            const quizQuestions = [
                {
                    question: "Who are Marion Regier's children?",
                    answers: ["Jerry, Christopher, Autumn, Jeremy, Wendell, Gwendolyn, Wayne, Twila", "Herman, Pete, Ruth, Ivan", "Tyler, Kelsey, Brock", "Whitney, Sterling, Saylor"],
                    correct: 0
                },
                {
                    question: "How many children do Christopher & Crystal have?",
                    answers: ["3", "4", "5", "6"],
                    correct: 2
                },
                {
                    question: "Who are Haisley, Nella, Cash, and Henry's parents?",
                    answers: ["Sterling & Kyla", "Whitney & Aaron", "Saylor & Bobbie", "Tyler"],
                    correct: 1
                },
                {
                    question: "Which family member died at age 1?",
                    answers: ["Marion", "Harold", "Wendell", "Henry"],
                    correct: 2
                },
                {
                    question: "Who is married to Michaja?",
                    answers: ["Daen Glover", "Shaedon Glover", "Tyler Doerksen", "Brock Doerksen"],
                    correct: 1
                },
                {
                    question: "How many grandchildren (Gen 3) does Marion have?",
                    answers: ["5", "10", "15", "20"],
                    correct: 1
                },
                {
                    question: "Who are Finley and Ava's parents?",
                    answers: ["Whitney & Aaron", "Sterling & Kyla", "Saylor & Bobbie", "Christopher & Crystal"],
                    correct: 1
                },
                {
                    question: "What generation are Justice and Quincy?",
                    answers: ["Generation 1", "Generation 2", "Generation 3", "Generation 4"],
                    correct: 2
                }
            ];

            const container = document.getElementById('quizContainer');
            let html = '<div style="max-width: 700px; margin: 0 auto;">';

            quizQuestions.forEach((q, qIdx) => {
                const answered = localStorage.getItem(`quiz-${qIdx}`);
                const isCorrect = answered === q.correct.toString();

                html += `
                    <div style="background: white; padding: 20px; margin-bottom: 20px; border-radius: 12px; border-left: 4px solid var(--doerksen);">
                        <h4 style="margin: 0 0 15px 0;">${qIdx + 1}. ${q.question}</h4>
                        <div style="display: flex; flex-direction: column; gap: 10px;">
                `;

                q.answers.forEach((answer, aIdx) => {
                    const isSelected = answered === aIdx.toString();
                    const showResult = answered !== null;
                    let bgColor = 'var(--bg-light)';
                    let borderColor = 'var(--border)';

                    if (showResult) {
                        if (aIdx === q.correct) {
                            bgColor = '#d4edda';
                            borderColor = 'var(--pete)';
                        } else if (isSelected && !isCorrect) {
                            bgColor = '#f8d7da';
                            borderColor = 'var(--donald)';
                        }
                    }

                    html += `
                        <button onclick="answerQuiz(${qIdx}, ${aIdx}, ${q.correct})" style="
                            padding: 12px;
                            background: ${bgColor};
                            border: 2px solid ${borderColor};
                            border-radius: 6px;
                            cursor: pointer;
                            text-align: left;
                            transition: all 0.3s;
                        ">
                            ${isSelected ? (isCorrect ? '✓ ' : '✗ ') : ''}${answer}
                        </button>
                    `;
                });

                html += `
                        </div>
                    </div>
                `;
            });

            html += '</div>';

            const score = quizQuestions.filter((q, idx) => localStorage.getItem(`quiz-${idx}`) === q.correct.toString()).length;
            html += `
                <div style="text-align: center; margin-top: 20px; padding: 20px; background: var(--bg-light); border-radius: 12px;">
                    <h3>Score: ${score} / ${quizQuestions.length}</h3>
                    <button onclick="resetQuiz()" style="margin-top: 10px; padding: 10px 20px; background: var(--donald); color: white; border: none; border-radius: 6px; cursor: pointer;">
                        Reset Quiz
                    </button>
                </div>
            `;

            container.innerHTML = html;
        }

        function answerQuiz(questionIdx, answerIdx, correctIdx) {
            localStorage.setItem(`quiz-${questionIdx}`, answerIdx.toString());
            generateQuiz();
        }

        function resetQuiz() {
            for (let i = 0; i < 10; i++) {
                localStorage.removeItem(`quiz-${i}`);
            }
            generateQuiz();
        }

        // Initialize app
        function initializeApp() {
            console.log('Regier Family Tree App Initialized');
            renderFamilyTree();
            populateLocationFilter();
            calculateStats();
            generateWhosWho();
            generateBingo();
            generatePassport();
            generateQuiz();
        }
    </script>
</body>
</html>
